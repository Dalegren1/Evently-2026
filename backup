.container { 
    display: flex;
    justify-content: space-between;
    max-width: 1200px;
    border: 1px solid white;
}

.text-box {
    display:flex;
    flex-direction: column;
    padding-right: 50px;
}

.flex {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    gap: 1rem;
    height: 200px;
}

.flex-item1 {
    background-color: #645ff2;
    padding: 1rem;
    border-radius: .25rem;
    flex-grow: 0;
    flex-shrink: 1;
    flex-basis: 100%;
}

.flex-item2,
.flex-item3
{
    background-color: black;
    flex-grow: 1;
    flex-shrink: 0;
    flex-basis: 0;
}